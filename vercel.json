{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "routes": [
    {
      "src": "^/(assets|robots\\.txt)/(.*)",
      "dest": "/$1/$2",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "dist/server/server.js"
    }
  ]
}
